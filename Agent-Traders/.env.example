ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here

# Safe default. Live trading is intentionally blocked by the beginner CLI.
ALPACA_TRADING_MODE=paper

# IEX is free for most Alpaca accounts. SIP may require a paid data subscription.
ALPACA_DATA_FEED=iex

# Maximum dollars used for a single paper buy order.
MAX_TRADE_VALUE=100

# Conservative defaults for `python main.py run-bot`.
# Alpaca aggregates positions by ticker, so this is max whole shares per symbol.
MAX_SYMBOL_QUANTITY=3
MAX_TRADES_PER_DAY=5
LOSS_TOLERANCE_PCT=5
MIN_BUY_SCORE=6
BOT_INTERVAL_SECONDS=300
